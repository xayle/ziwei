  {
    "id": "zw_mw_010",
    "source": "《紫微斗数全书》",
    "text": "廉贞在寅申等宫庙旺，主政治手腕。",
    "category": "庙旺",
    "tags": [
      "廉贞庙旺"
    ],
    "source_page": "卷三·庙旺 p.130",
    "ctext_page": 130,
    "ctext_ref": "https://ctext.org/wiki.pl?if=en&res=979714&chapter=130"
  },
  {
    "id": "zw_fly_001",
    "source": "《紫微斗数全书》",
    "text": "飞星以宫干四化飞入诸宫，观禄权科忌之落点定吉凶。",
    "category": "飞星",
    "tags": [
      "飞星"
    ],
    "source_page": "卷四·飞星 p.131",
    "ctext_page": 131,
    "ctext_ref": "https://ctext.org/wiki.pl?if=en&res=979714&chapter=131"
  },
  {
    "id": "zw_fly_002",
    "source": "《紫微斗数全书》",
    "text": "宫干四化飞回本宫为自化，主该宫事体自我转化。",
    "category": "飞星",
    "tags": [
      "自化"
    ],
    "source_page": "卷四·飞星 p.132",
    "ctext_page": 132,
    "ctext_ref": "https://ctext.org/wiki.pl?if=en&res=979714&chapter=132"
  },
  {
    "id": "zw_fly_003",
    "source": "《紫微斗数全书》",
    "text": "飞化落宫之对宫受冲，主暗中波及。",
    "category": "飞星",
    "tags": [
      "飞化冲"
    ],
    "source_page": "卷四·飞星 p.133",
    "ctext_page": 133,
    "ctext_ref": "https://ctext.org/wiki.pl?if=en&res=979714&chapter=133"
  },
  {
    "id": "zw_fly_004",
    "source": "《紫微斗数全书》",
    "text": "化禄飞入财帛宫，主财源机缘。",
    "category": "飞星",
    "tags": [
      "化禄飞财"
    ],
    "source_page": "卷四·飞星 p.134",
    "ctext_page": 134,
    "ctext_ref": "https://ctext.org/wiki.pl?if=en&res=979714&chapter=134"
  },
  {
    "id": "zw_fly_005",
    "source": "《紫微斗数全书》",
    "text": "化忌飞入命宫，主阻滞亏欠，宜修身化解。",
    "category": "飞星",
