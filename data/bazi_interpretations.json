{
  "jianchus": {
    "0": {
      "name": "建",
      "desc": "气专而强，宜官府公事等。宜：赴任、祈福、求嗣、求财、交涉、出行。忌：上梁、嫁娶、安葬。"
    },
    "1": {
      "name": "除",
      "desc": "除旧布新的日子。宜：祭祀、祈福、嫁娶、出行、入宅、动土、开光、交易。忌：嫁娶、探病。"
    },
    "2": {
      "name": "满",
      "desc": "丰收之意。宜：嫁娶、祈福、出行、安床、求财、裁衣、祭祀。忌：造葬、赴任、求医。"
    },
    "3": {
      "name": "平",
      "desc": "普通的日子。宜：修造、粉刷墙壁、修补。忌：出行。"
    },
    "4": {
      "name": "定",
      "desc": "月令三合的日子。宜：祭祀、祈福、嫁娶、造屋、求嗣、纳财。忌：诉讼、出行、交涉。"
    },
    "5": {
      "name": "执",
      "desc": "守成之意。宜：纳采、嫁娶、动土、入殓。忌：入宅、开市。"
    },
    "6": {
      "name": "破",
      "desc": "日月相冲，曰大耗，诸事不宜。宜：破屋坏垣。忌：不宜诸吉事。"
    },
    "7": {
      "name": "危",
      "desc": "吉事不取的日子。宜：入殓、破土、火化、进塔、安葬。忌：入宅嫁娶诸吉事。"
    },
    "8": {
      "name": "成",
      "desc": "月支的三合日，吉神的日子。宜：结婚、开市、修造、动土、安床、破土、安葬、搬迁、交易、求财、出行、立契。忌：诉讼。"
    },
    "9": {
      "name": "收",
      "desc": "收成、收获的日子。宜：祈福、求嗣、赴任、嫁娶、安床、修造、动土、求学、开市、交易、买卖、立契。忌：破土、安葬。"
    },
    "10": {
      "name": "开",
      "desc": "重新开展的好日子。宜：祭祀、祈福、开光、入宅、嫁娶、上任、修造、动土、开市、安床、交易、出行、竖柱。忌：诉讼、安葬。"
    },
    "11": {
      "name": "闭",
      "desc": "闭藏的日子。宜：安门、伐木、修造、动土。忌：出行、嫁娶。"
    }
  },
