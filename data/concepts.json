[
  {
    "id": "BZ001",
    "term": "日主",
    "category": "bazi",
    "definition": "八字中日柱天干，代表命主本人，是判断五行旺衰与格局用神的核心依据。",
    "aliases": ["日干", "我"],
    "related": ["旺衰", "用神", "喜神"]
  },
  {
    "id": "BZ002",
    "term": "用神",
    "category": "bazi",
    "definition": "调节八字五行平衡的关键神（天干或地支藏干），一般分调候用神、格局用神、病药用神。",
    "aliases": [],
    "related": ["喜神", "忌神", "格局"]
  },
  {
    "id": "BZ003",
    "term": "格局",
    "category": "bazi",
    "definition": "依据月令所藏主气及四柱配合确定的命盘结构，如正官格、七杀格、食神格、伤官格、财格、印格等。",
    "aliases": ["格"],
    "related": ["月令", "用神", "清纯"]
  },
  {
    "id": "BZ004",
    "term": "七杀",
    "category": "bazi",
    "definition": "克制日主且阴阳相同的十神。力量强劲，无制则凶，有制（食神制杀、印绶化杀）则可成贵格。",
    "aliases": ["偏官"],
    "related": ["制杀", "化杀", "印绶"]
  },
  {
    "id": "BZ005",
    "term": "正官",
    "category": "bazi",
    "definition": "克制日主且阴阳相异的十神，代表规则、责任、名誉。正官格以清纯为贵，忌混杀。",
    "aliases": [],
    "related": ["七杀", "印绶", "官印相生"]
  },
  {
    "id": "BZ006",
    "term": "食神",
    "category": "bazi",
    "definition": "日主所生且阴阳相同的十神，代表才华、口福、表达能力。食神制杀可成贵格。",
    "aliases": ["食"],
    "related": ["伤官", "七杀", "泄秀"]
  },
  {
    "id": "BZ007",
    "term": "伤官",
    "category": "bazi",
    "definition": "日主所生且阴阳相异的十神，具有克官之力，主聪慧但叛逆。伤官见官，行运多是非。",
    "aliases": ["伤"],
    "related": ["食神", "配印", "官"]
  },
  {
    "id": "BZ008",
    "term": "正财",
    "category": "bazi",
    "definition": "日主所克且阴阳相异的十神，代表正当收入与配偶（男命）。财旺身弱须行比劫运护身。",
    "aliases": [],
    "related": ["偏财", "日主旺衰", "财星"]
  },
  {
    "id": "BZ009",
    "term": "偏财",
    "category": "bazi",
    "definition": "日主所克且阴阳相同的十神，代表意外之财、父亲、偏业收入。偏财格主为人慷慨好交游。",
    "aliases": [],
    "related": ["正财", "七杀", "驿马"]
  },
  {
    "id": "BZ010",
    "term": "正印",
    "category": "bazi",
    "definition": "生日主且阴阳相异的十神，代表母亲、文书、学识，可化七杀为用。印旺过重则好逸恶劳。",
    "aliases": ["印绶"],
    "related": ["偏印", "化杀", "生身"]
  },
  {
    "id": "BZ011",
    "term": "偏印",
    "category": "bazi",
    "definition": "生日主且阴阳相同的十神，又称枭神，能夺食神之用。主偏门技艺、直觉敏锐、较固执。",
    "aliases": ["枭神", "倒食"],
    "related": ["正印", "食神", "制枭"]
  },
  {
    "id": "BZ012",
    "term": "比肩",
    "category": "bazi",
    "definition": "与日主五行相同且阴阳相同的十神，代表兄弟、竞争者、合作伙伴，有助身之力。",
    "aliases": ["比"],
    "related": ["劫财", "群劫争财", "护财"]
  },
  {
    "id": "BZ013",
    "term": "劫财",
    "category": "bazi",
    "definition": "与日主五行相同且阴阳相异的十神，性质比比肩更强势，代表争夺之意，主财来财去。",
    "aliases": ["劫"],
    "related": ["比肩", "财", "羊刃"]
  },
  {
    "id": "BZ014",
    "term": "大运",
    "category": "bazi",
    "definition": "以每10年为一步的行运周期，从出生后的首个节气推算，是判断人生阶段性吉凶的关键。",
    "aliases": ["运"],
    "related": ["流年", "行运方向", "交运年龄"]
  },
  {
    "id": "BZ015",
    "term": "流年",
    "category": "bazi",
    "definition": "即当年太岁年柱干支，与命局、大运叠加分析，判断该年具体的事件吉凶走向。",
    "aliases": ["太岁", "岁运"],
    "related": ["大运", "太岁冲命", "伏吟"]
  },
  {
    "id": "BZ016",
    "term": "羊刃",
    "category": "bazi",
    "definition": "日主五行帝旺之地，为极旺之象。羊刃格主魄力、执行力强，但亦主争竞、伤旺。",
    "aliases": ["刃"],
    "related": ["七杀", "劫财", "帝旺"]
  },
  {
    "id": "BZ017",
    "term": "桃花",
    "category": "bazi",
    "definition": "神煞之一，又称咸池。子午卯酉年支见，主感情丰富、异性缘旺，亦主风流多情之象。",
    "aliases": ["咸池"],
    "related": ["驿马", "天乙贵人", "神煞"]
  },
  {
    "id": "BZ018",
    "term": "驿马",
    "category": "bazi",
    "definition": "神煞之一。寅申巳亥年支见，主奔波变动、出行迁移。驿马临财官，主因变动得财。",
    "aliases": [],
    "related": ["桃花", "神煞", "流年变动"]
  },
  {
    "id": "ZW001",
    "term": "命宫",
    "category": "ziwei",
    "definition": "紫微斗数中十二宫之首，代表命主本质、外表与先天禀赋，是整个命盘解读的出发点。",
    "aliases": [],
    "related": ["身宫", "十二宫", "主星"]
  },
  {
    "id": "ZW002",
    "term": "紫微星",
    "category": "ziwei",
    "definition": "紫微斗数中最重要的帝王星，主尊贵、领导力与掌控欲。入命宫主天生具有领袖气质。",
    "aliases": ["帝星"],
    "related": ["天府星", "辅弼", "命宫"]
  },
  {
    "id": "ZW003",
    "term": "天府星",
    "category": "ziwei",
    "definition": "南斗主星，主财帛与仓库，性稳重保守。与紫微对宫，有守护资产之力。",
    "aliases": [],
    "related": ["紫微星", "财帛宫", "南斗"]
  },
  {
    "id": "ZW004",
    "term": "四化",
    "category": "ziwei",
    "definition": "化禄、化权、化科、化忌四种星曜变化，对所在宫位及对宫产生增强或干扰作用。",
    "aliases": ["星曜四化"],
    "related": ["化禄", "化忌", "飞化"]
  },
  {
    "id": "ZW005",
    "term": "大限",
    "category": "ziwei",
    "definition": "紫微斗数中每10年一步的行运，从命宫起步依顺逆方向行进十二宫，判断阶段命运。",
    "aliases": ["限运"],
    "related": ["小限", "流年", "流月"]
  }
]
