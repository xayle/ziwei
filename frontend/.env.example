# Frontend runtime API base URL (optional)
# - Empty (default): use same-origin '/' and rely on Vite proxy in dev
# - Example: http://127.0.0.1:8003
VITE_API_BASE_URL=

# Vite dev proxy target for /api (optional)
# Use this when local backend auto-fallbacks from 8000 to another free port
# Example: http://127.0.0.1:8003
VITE_DEV_API_TARGET=http://127.0.0.1:8000
