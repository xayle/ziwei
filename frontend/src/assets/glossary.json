[
  {"term": "八字", "pinyin": "bā zì", "definition": "用出生年月日时的天干地支组成四组字，共八字，是命理推算的基础材料。", "category": "其他", "classic_source": "《渊海子平》"},
  {"term": "天干", "pinyin": "tiān gān", "definition": "甲乙丙丁戊己庚辛壬癸十个符号，代表天的气运，与地支配合计算命局。", "category": "其他", "classic_source": "《三命通会》"},
  {"term": "地支", "pinyin": "dì zhī", "definition": "子丑寅卯辰巳午未申酉戌亥十二个符号，代表地的气运，含藏干。", "category": "其他", "classic_source": "《三命通会》"},
  {"term": "四柱", "pinyin": "sì zhù", "definition": "年柱、月柱、日柱、时柱，各由一天干一地支组成，是八字的基本结构。", "category": "其他", "classic_source": "《子平真诠》"},
  {"term": "干支", "pinyin": "gān zhī", "definition": "天干与地支的合称，60甲子为一个完整周期，用于记年、月、日、时。", "category": "其他", "classic_source": "《三命通会》"},
  {"term": "日主", "pinyin": "rì zhǔ", "definition": "日柱天干，代表命主本人，是八字分析的核心参照点。", "category": "其他", "classic_source": "《子平真诠》"},
  {"term": "五行", "pinyin": "wǔ xíng", "definition": "金、木、水、火、土五种基本物质属性，天干地支均有对应五行，相生相克构成命理运势变化。", "category": "五行", "classic_source": "《滴天髓》"},
  {"term": "相生", "pinyin": "xiāng shēng", "definition": "五行间的促进关系：木生火、火生土、土生金、金生水、水生木。", "category": "五行", "classic_source": "《三命通会》"},
  {"term": "相克", "pinyin": "xiāng kè", "definition": "五行间的制约关系：木克土、土克水、水克火、火克金、金克木。", "category": "五行", "classic_source": "《三命通会》"},
  {"term": "火", "pinyin": "huǒ", "definition": "五行之一，对应心脏/小肠，方位南，季节夏，颜色红，性情热烈积极。", "category": "五行", "classic_source": "《滴天髓》"},
  {"term": "水", "pinyin": "shuǐ", "definition": "五行之一，对应肾/膀胱，方位北，季节冬，颜色黑蓝，性情智慧灵活。", "category": "五行", "classic_source": "《滴天髓》"},
  {"term": "木", "pinyin": "mù", "definition": "五行之一，对应肝胆，方位东，季节春，颜色绿，性情仁慈进取。", "category": "五行", "classic_source": "《滴天髓》"},
  {"term": "金", "pinyin": "jīn", "definition": "五行之一，对应肺/大肠，方位西，季节秋，颜色白，性情刚毅果断。", "category": "五行", "classic_source": "《滴天髓》"},
  {"term": "土", "pinyin": "tǔ", "definition": "五行之一，对应脾胃，方位中央，四季末各18天，颜色黄，性情稳重包容。", "category": "五行", "classic_source": "《滴天髓》"},
  {"term": "十神", "pinyin": "shí shén", "definition": "比肩、劫财、食神、伤官、偏财、正财、七杀、正官、偏印、正印，以日主与其他天干的五行生克关系划分。", "category": "十神", "classic_source": "《子平真诠》"},
  {"term": "比肩", "pinyin": "bǐ jiān", "definition": "与日主同五行、同阴阳的天干，代表平辈朋友兄弟，助力日主。", "category": "十神", "classic_source": "《子平真诠》"},
  {"term": "劫财", "pinyin": "jié cái", "definition": "与日主同五行、异阴阳的天干，竞争争夺之意，财帛易受损。", "category": "十神", "classic_source": "《子平真诠》"},
  {"term": "食神", "pinyin": "shí shén", "definition": "日主所生且同阴阳的天干，代表才华、表达、食禄，吉星之一。", "category": "十神", "classic_source": "《子平真诠》"},
  {"term": "伤官", "pinyin": "shāng guān", "definition": "日主所生且异阴阳的天干，才华外露但克官，艺术/技术倾向强。", "category": "十神", "classic_source": "《子平真诠》"},
  {"term": "正财", "pinyin": "zhèng cái", "definition": "日主所克且异阴阳的天干，代表稳定薪资财禄，男命代表妻子。", "category": "十神", "classic_source": "《子平真诠》"},
  {"term": "偏财", "pinyin": "piān cái", "definition": "日主所克且同阴阳的天干，代表偏门财、横财，偏财旺利于商业。", "category": "十神", "classic_source": "《子平真诠》"},
  {"term": "七杀", "pinyin": "qī shā", "definition": "克制日主且同阴阳的天干，杀气重，有则宜制化，制化得宜则成大格。", "category": "十神", "classic_source": "《子平真诠》"},
  {"term": "正官", "pinyin": "zhèng guān", "definition": "克制日主且异阴阳的天干，代表权威名誉，女命代表丈夫（正缘）。", "category": "十神", "classic_source": "《子平真诠》"},
  {"term": "偏印", "pinyin": "piān yìn", "definition": "生助日主且同阴阳的天干，又称枭神，学业成就但独立孤僻倾向。", "category": "十神", "classic_source": "《子平真诠》"},
  {"term": "正印", "pinyin": "zhèng yìn", "definition": "生助日主且异阴阳的天干，代表母亲、贵人、学问、精神支柱。", "category": "十神", "classic_source": "《子平真诠》"},
  {"term": "格局", "pinyin": "gé jú", "definition": "命局的整体结构类型，由月令透出天干来确定，分上格、中格、下格，是命运等级的核心判断。", "category": "格局", "classic_source": "《子平真诠·论用神》"},
  {"term": "七杀格", "pinyin": "qī shā gé", "definition": "月干透七杀所成格局，为外格之一，制化得宜则发贵，无制则刚强凶险。", "category": "格局", "classic_source": "《子平真诠》"},
  {"term": "正官格", "pinyin": "zhèng guān gé", "definition": "月令正官透天干，代表正途仕途，名誉地位俱佳，为最正统吉格之一。", "category": "格局", "classic_source": "《子平真诠》"},
  {"term": "食神格", "pinyin": "shí shén gé", "definition": "月令食神透天干，主食禄丰厚、才华出众，寿考之格。", "category": "格局", "classic_source": "《子平真诠》"},
  {"term": "伤官格", "pinyin": "shāng guān gé", "definition": "月令伤官透天干，才华横溢而克官，配印则贵，傲慢孤清之格。", "category": "格局", "classic_source": "《子平真诠》"},
  {"term": "正财格", "pinyin": "zhèng cái gé", "definition": "月令正财透天干，守成致富，适合稳定职业，诚信积累财富。", "category": "格局", "classic_source": "《子平真诠》"},
  {"term": "偏财格", "pinyin": "piān cái gé", "definition": "月令偏财透天干，善于经商理财，偏门求财，广结人缘。", "category": "格局", "classic_source": "《子平真诠》"},
  {"term": "正印格", "pinyin": "zhèng yìn gé", "definition": "月令正印透天干，学识渊博，贵人相助，适合学术文职。", "category": "格局", "classic_source": "《子平真诠》"},
  {"term": "偏印格", "pinyin": "piān yìn gé", "definition": "月令偏印透天干，才艺特异，独立孤行，思维另辟蹊径。", "category": "格局", "classic_source": "《子平真诠》"},
  {"term": "用神", "pinyin": "yòng shén", "definition": "命局中对日主最有帮助的五行，通常由日主强弱与格局共同决定，是命运调候的核心。", "category": "其他", "classic_source": "《子平真诠·论用神》"},
  {"term": "忌神", "pinyin": "jì shén", "definition": "与用神相对，对命局运势起负面作用的五行，遇之则诸事不顺。", "category": "其他", "classic_source": "《滴天髓》"},
  {"term": "日主强弱", "pinyin": "rì zhǔ qiáng ruò", "definition": "衡量日主在命局中五行力量的强弱状态，分身强、中和、身弱，影响用神取向。", "category": "其他", "classic_source": "《滴天髓》"},
  {"term": "大运", "pinyin": "dà yùn", "definition": "每十年一步的后天运程，由出生月柱顺逆排定，与流年共同影响命运走势。", "category": "大运", "classic_source": "《三命通会》"},
  {"term": "顺行大运", "pinyin": "shùn xíng dà yùn", "definition": "阳年生男命、阴年生女命从出生月柱向后顺排大运，即往未来节气方向推算。", "category": "大运", "classic_source": "《三命通会》"},
  {"term": "逆行大运", "pinyin": "nì xíng dà yùn", "definition": "阴年生男命、阳年生女命从出生月柱向前逆排大运，即往过去节气方向推算。", "category": "大运", "classic_source": "《三命通会》"},
  {"term": "起运年龄", "pinyin": "qǐ yùn nián líng", "definition": "大运起始的实际年龄，由出生到最近节气的天数除以3或乘以3推算。", "category": "大运", "classic_source": "《三命通会》"},
  {"term": "流年", "pinyin": "liú nián", "definition": "每一公历年对应的干支，与大运、命局相互作用，产生当年吉凶变化。", "category": "大运", "classic_source": "《渊海子平》"},
  {"term": "太岁", "pinyin": "tài suì", "definition": "当年流年地支，与命局年支正冲则犯太岁冲，形成动荡变化之象。", "category": "大运", "classic_source": "《渊海子平》"},
  {"term": "神煞", "pinyin": "shén shà", "definition": "根据天干地支关系推导的吉凶辅助信息，如天乙贵人、文昌星、驿马、桃花等。", "category": "神煞", "classic_source": "《三命通会》"},
  {"term": "天乙贵人", "pinyin": "tiān yǐ guì rén", "definition": "命局中逢贵人相助的吉神，遇之可化险为夷，逢凶化吉，一生贵人运佳。", "category": "神煞", "classic_source": "《三命通会》"},
  {"term": "文昌贵人", "pinyin": "wén chāng guì rén", "definition": "主聪明学业吉祥的神煞，命中有文昌者，利于读书考试，文思敏捷。", "category": "神煞", "classic_source": "《三命通会》"},
  {"term": "驿马", "pinyin": "yì mǎ", "definition": "主动变、出行、迁移的神煞，逢驿马流年大运，宜出行、换工作或迁居。", "category": "神煞", "classic_source": "《三命通会》"},
  {"term": "桃花", "pinyin": "táo huā", "definition": "主异性缘分和社交魅力的神煞，子午卯酉为咸池桃花，命中多桃花则感情丰富。", "category": "神煞", "classic_source": "《三命通会》"},
  {"term": "劫煞", "pinyin": "jié shà", "definition": "主损财破财的凶煞，流年犯劫煞需谨慎投资，防钱财损失及官非。", "category": "神煞", "classic_source": "《三命通会》"},
  {"term": "亡神", "pinyin": "wáng shén", "definition": "主精神耗损、意外失败的凶煞，逢之宜静不宜动，注意身体健康。", "category": "神煞", "classic_source": "《三命通会》"},
  {"term": "白虎", "pinyin": "bái hǔ", "definition": "主意外血光之灾的凶煞，逢白虎年大运需注意交通安全和健康。", "category": "神煞", "classic_source": "《三命通会》"},
  {"term": "华盖", "pinyin": "huá gài", "definition": "主孤独、宗教、艺术的神煞，命中有华盖者，利于文艺创作，精神世界丰富。", "category": "神煞", "classic_source": "《三命通会》"},
  {"term": "节气", "pinyin": "jié qì", "definition": "太阳历的24个时间节点，其中12个『节』对应月柱交接，是大运排算的关键锚点。", "category": "其他", "classic_source": "《三命通会》"},
  {"term": "真太阳时", "pinyin": "zhēn tài yáng shí", "definition": "以太阳过中天为正午的时间，与标准时间有差异，精确推算四柱时柱需用真太阳时修正。", "category": "其他", "classic_source": null},
  {"term": "时柱", "pinyin": "shí zhù", "definition": "出生时辰对应的天干地支，代表晚年及子女宫，时柱精确性影响命局解读。", "category": "其他", "classic_source": "《三命通会》"},
  {"term": "月令", "pinyin": "yuè lìng", "definition": "月支，代表时令旺衰，是取格局的核心依据，『月令得用』是格成的首要条件。", "category": "格局", "classic_source": "《子平真诠》"},
  {"term": "藏干", "pinyin": "cáng gān", "definition": "地支内含藏的天干，如子藏癸水、午藏丁己，参与五行力量计算。", "category": "其他", "classic_source": "《三命通会》"},
  {"term": "六合", "pinyin": "liù hé", "definition": "地支间成对和合的关系：子丑合、寅亥合、卯戌合、辰酉合、巳申合、午未合，和合则化或增力。", "category": "其他", "classic_source": "《三命通会》"},
  {"term": "三合", "pinyin": "sān hé", "definition": "三个地支组成合局化五行：申子辰水局、亥卯未木局、寅午戌火局、巳酉丑金局。", "category": "其他", "classic_source": "《三命通会》"},
  {"term": "六冲", "pinyin": "liù chōng", "definition": "六组地支相冲关系：子午冲、丑未冲、寅申冲、卯酉冲、辰戌冲、巳亥冲，冲克带来动荡变化。", "category": "其他", "classic_source": "《三命通会》"},
  {"term": "刑", "pinyin": "xíng", "definition": "地支三刑关系：寅巳申无恩之刑、丑戌未持势之刑、子卯无礼之刑、辰辰午午酉酉亥亥自刑，主官非和纷争。", "category": "其他", "classic_source": "《三命通会》"},
  {"term": "害", "pinyin": "hài", "definition": "六组地支相害：子未害、丑午害、寅巳害、卯辰害、申亥害、酉戌害，主阻碍与暗中损害。", "category": "其他", "classic_source": "《三命通会》"},
  {"term": "长生十二宫", "pinyin": "cháng shēng shí èr gōng", "definition": "天干在地支的旺衰十二状态：长生、沐浴、冠带、临官、帝旺、衰、病、死、墓、绝、胎、养。", "category": "其他", "classic_source": "《三命通会》"},
  {"term": "调候", "pinyin": "tiáo hòu", "definition": "根据出生月令寒暖燥湿来选取用神的方法，如严冬水命需火暖，酷夏火命需水润。", "category": "其他", "classic_source": "《滴天髓》"},
  {"term": "空亡", "pinyin": "kōng wáng", "definition": "六十甲子中，每旬天干10个而地支用12个，余出的2个地支称为空亡，所落之地支力量减弱。", "category": "其他", "classic_source": "《三命通会》"}
]
