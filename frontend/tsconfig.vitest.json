{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": [
    "src/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.vitest.tsbuildinfo",

    "paths": {
      "@/*": ["./src/*"]
    },

    "types": ["vitest/globals"],

    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  }
}
