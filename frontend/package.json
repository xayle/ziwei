{
  "name": "bazi-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "sync:api": "pwsh ../scripts/sync_frontend_env.ps1",
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint src/ --max-warnings 100",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "install:e2e": "pwsh ./scripts/install-playwright.ps1",
    "test:coverage": "vitest run --coverage",
    "ci": "npm run type-check && npm run lint && npm run test && npm run build",
    "gen:types": "openapi-typescript ../docs/openapi.json -o src/api/schema.d.ts"
  },
  "dependencies": {
    "@lucide/vue": "^1.16.0",
    "axios": "^1.7.9",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.2",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.51.0",
    "@tsconfig/node22": "^22.0.5",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^4.1.1",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "jsdom": "^29.0.1",
    "openapi-typescript": "^7.13.0",
    "typescript": "~5.8.3",
    "vite": "^6.0.11",
    "vitest": "^4.1.1",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.2.12"
  }
}
