{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fusheng.local/contracts/relation-compat@1.0",
  "title": "RelationCompatResponse",
  "description": "双人关系合盘 · 统一响应形状。个人单盘仍用 bazi_full@5.1 / ziwei full；本 schema 仅覆盖 relation/full。",
  "type": "object",
  "required": [
    "schema_version",
    "relation_type",
    "person_a",
    "person_b",
    "combined_score",
    "summary",
    "disclaimer_block",
    "layers",
    "dimensions",
    "timeline",
    "missing_fields"
  ],
  "properties": {
    "schema_version": { "const": "relation-compat@1.0" },
    "request_id": { "type": "string" },
    "relation_type": {
      "enum": [
        "couple",
        "friend",
        "parent_child",
        "colleague",
        "business_partner",
        "supervisor_subordinate"
      ]
    },
    "relation_type_label": {
      "type": "string",
      "description": "UI 文案，如 情侣合盘 / 友人合盘"
    },
    "person_a": { "$ref": "#/$defs/PersonRef" },
    "person_b": { "$ref": "#/$defs/PersonRef" },
    "combined_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "加权综合分；分项见 dimensions"
    },
    "grade": {
      "enum": ["上上", "上", "中", "下", "下下", "N/A"]
    },
    "summary": { "type": "string", "maxLength": 280 },
    "summary_cards": {
      "type": "array",
      "maxItems": 5,
      "items": { "$ref": "#/$defs/SummaryCard" },
      "description": "首屏 3–5 条，禁止长文替代"
    },
    "disclaimer_block": { "$ref": "life-volume.schema.json#/$defs/DisclaimerBlock" },
    "layers": {
      "type": "object",
      "required": ["fact", "cite", "inference"],
      "properties": {
        "fact": { "$ref": "#/$defs/LayerBlock" },
        "cite": { "$ref": "#/$defs/LayerBlock" },
        "inference": { "$ref": "#/$defs/LayerBlock" }
      }
    },
    "dimensions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/DimensionScore" }
    },
    "bazi": { "$ref": "#/$defs/EngineSection" },
    "ziwei": { "$ref": "#/$defs/EngineSection" },
    "palace_cross": {
      "type": "array",
      "items": { "$ref": "#/$defs/PalaceCross" },
      "description": "按 relation_type 选取的宫位互涉"
    },
    "timeline": {
      "type": "array",
      "items": { "$ref": "#/$defs/TimelineNode" },
      "description": "双人共运节点（默认 ±2 年）"
    },
    "action_items": {
      "type": "array",
      "maxItems": 8,
      "items": { "$ref": "#/$defs/ActionItem" }
    },
    "tensions": {
      "type": "array",
      "items": { "$ref": "#/$defs/TensionNote" },
      "description": "模块间矛盾显式标注，如大运财 vs wealth_analysis"
    },
    "missing_fields": {
      "type": "array",
      "items": { "type": "string" }
    },
    "meta": {
      "type": "object",
      "properties": {
        "chart_hash_a": { "type": "string" },
        "chart_hash_b": { "type": "string" },
        "rule_version": { "type": "string" },
        "layer": { "const": "heuristic" }
      }
    }
  },
  "$defs": {
    "PersonRef": {
      "type": "object",
      "required": ["label", "gender", "birth_solar", "pillars_primary"],
      "properties": {
        "case_id": { "type": "string" },
        "label": { "type": "string" },
        "gender": { "type": "string" },
        "birth_solar": { "type": "string" },
        "pillars_primary": { "type": "object" },
        "life_palace_gz": { "type": "string" },
        "wuxing_ju_name": { "type": "string" }
      }
    },
    "SummaryCard": {
      "type": "object",
      "required": ["id", "tone", "text"],
      "properties": {
        "id": { "type": "string" },
        "tone": { "enum": ["support", "conflict", "neutral", "action"] },
        "text": { "type": "string", "maxLength": 120 }
      }
    },
    "LayerBlock": {
      "type": "object",
      "properties": {
        "collapsed_default": { "type": "boolean" },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "heading", "blocks"],
            "properties": {
              "id": { "type": "string" },
              "heading": { "type": "string" },
              "blocks": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["text"],
                  "properties": {
                    "text": { "type": "string" },
                    "classic_id": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "DimensionScore": {
      "type": "object",
      "required": ["id", "label", "score", "max_score", "weight", "description", "layer"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "score": { "type": "number" },
        "max_score": { "type": "number" },
        "weight": { "type": "number", "description": "合成 combined_score 的权重" },
        "description": { "type": "string", "maxLength": 400 },
        "layer": { "enum": ["fact", "cite", "inference"] },
        "engine": { "enum": ["bazi", "ziwei", "fusion"] }
      }
    },
    "EngineSection": {
      "type": "object",
      "properties": {
        "score": { "type": "number" },
        "max_score": { "type": "number" },
        "dimensions": {
          "type": "array",
          "items": { "$ref": "#/$defs/DimensionScore" }
        },
        "harmony_points": { "type": "array", "items": { "type": "string" } },
        "conflict_points": { "type": "array", "items": { "type": "string" } }
      }
    },
    "PalaceCross": {
      "type": "object",
      "required": ["pair_id", "a_palace", "b_palace", "relation_tag", "summary"],
      "properties": {
        "pair_id": { "type": "string" },
        "a_palace": { "type": "string" },
        "b_palace": { "type": "string" },
        "relation_tag": { "type": "string" },
        "summary": { "type": "string", "maxLength": 300 },
        "layer": { "enum": ["fact", "inference"] }
      }
    },
    "TimelineNode": {
      "type": "object",
      "required": ["year", "label", "summary"],
      "properties": {
        "year": { "type": "integer" },
        "month": { "type": "integer" },
        "label": { "type": "string" },
        "summary": { "type": "string", "maxLength": 200 },
        "risk_level": { "enum": ["低", "中", "高"] }
      }
    },
    "ActionItem": {
      "type": "object",
      "required": ["id", "text"],
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string", "maxLength": 160 },
        "priority": { "enum": ["P0", "P1", "P2"] }
      }
    },
    "TensionNote": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    }
  }
}
