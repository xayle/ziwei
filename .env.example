# ===========================================================
# BaZi API v7.0 环境变量模板
# 复制此文件为 .env 并填入真实值。严禁将 .env 提交到 git。
# ===========================================================

# ---- 应用环境 ----
ENVIRONMENT=development       # development | staging | production
DEBUG=false
HOST=127.0.0.1
PORT=8000
BASE_URL=http://127.0.0.1:8000

# ---- 安全（必填）----
# 生成命令： python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=
ALGORITHM=HS256

# ---- 认证 ----
# 开发测试时可设 true 跳过登录，生产必须 false
AUTH_BYPASS=false
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- 数据库 ----
DATABASE_URL=sqlite:///./data/mingli.db
# DB_PATH=data/mingli.db

# ---- 日志 ----
LOG_LEVEL=INFO
LOG_FORMAT=json

# ---- 引擎开关 ----
# M1 完成后改为 true
ENGINE_V2=false

# ---- 性能 / 监控 ----
PROMETHEUS_ENABLED=true
RATE_LIMIT_ENABLED=true
SOLAR_TIME_ENABLED=false
UVICORN_WORKERS=4

