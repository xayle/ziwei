# ===========================================================
# BaZi API v8.0 环境变量模板
# 复制此文件为 .env 并填入真实值。严禁将 .env 提交到 git。
# ===========================================================

# ---- 应用基础 ----
APP_NAME=BaZi Service v8.0          # 应用名称（显示在日志/监控面板）
APP_ENV=development                   # development | staging | production
ENVIRONMENT=development               # 兼容旧字段，与 APP_ENV 保持一致
DEBUG=false                           # true 仅在开发环境，生产必须 false
HOST=127.0.0.1
PORT=8000
BASE_URL=http://127.0.0.1:8000

# ---- 安全（必填）----
# 生成命令： python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# ---- 认证 JWT ----
# 注意：config.py 读取 JWT_ALGORITHM（不是 ALGORITHM），请使用此名称
JWT_ALGORITHM=HS256                   # HS256 | RS256
AUTH_BYPASS=false                     # 开发测试时可设 true 跳过登录，生产必须 false
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- 数据库 ----
DATABASE_URL=sqlite:///./data/mingli.db
DB_PATH=data/mingli.db                # SQLite 文件路径（DATABASE_URL 优先）
DB_POOL_SIZE=20                       # 连接池大小（SQLite 无效，PostgreSQL 生效）
DB_MAX_OVERFLOW=30                    # 超出 pool_size 的最大额外连接数
DB_POOL_RECYCLE=3600                  # 连接回收时间（秒）

# ---- 引擎开关 ----
ENGINE_V2=true                        # true=使用 v2 引擎（M1 完成后设为 true）
PRIMARY_BACKEND=sxtwl                 # sxtwl | lunar_python

# ---- 真太阳时 ----
SOLAR_TIME_ENABLED=false              # true=启用真太阳时修正（需 DEFAULT_LON）
DEFAULT_LON=116.4                     # 默认经度（北京）

# ---- 日志 ----
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                       # json | text

# ---- 缓存 ----
CACHE_ENABLED=true                    # 总开关
CACHE_TTL_MEMBERS=600                 # 成员缓存 TTL（秒）
CACHE_TTL_EVENTS=300                  # 事件缓存 TTL（秒）
CACHE_TTL_CASES=1200                  # 案例缓存 TTL（秒）
REDIS_URL=                            # redis://localhost:6379/0（留空则用内存缓存）
REDIS_ENABLED=false                   # true=启用 Redis 缓存（需同时设置 REDIS_URL）

# ---- 性能 / 监控 ----
PROMETHEUS_ENABLED=true
METRICS_PORT=8001                     # Prometheus metrics 端口
UVICORN_WORKERS=4

# ---- 限速 ----
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100               # 默认限速（请求数）
RATE_LIMIT_WINDOW_SECONDS=60          # 限速时间窗口（秒）

# ---- 古籍语料（可选）----
# Chinese Text Project API key，用于子平真诠精确章节切块
# 申请：https://ctext.org/tools/subscribe
CTEXT_API_KEY=

# ---- CORS ----
# 多个域名用逗号分隔，如：http://localhost:3000,https://app.example.com
ALLOWED_ORIGINS=
