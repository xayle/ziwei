<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>八字命理验证 · BaZi Verify</title>
  <link rel="manifest" href="/static/manifest.json">
  <meta name="theme-color" content="#2563eb">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <!-- 外网受限环境下不加载 CDN 脚本；图表/Excel/PDF 功能自动降级 -->
  <style>
    /* ── 主题变量 ───────────────────────────────────── */
    :root {
      --bg:     #f4f6fb;
      --bg-grad:#f7f8fb;
      --panel:  #ffffff;
      --text:   #0f172a;
      --muted:  #5f6b86;
      --ok:     #16a34a;
      --warn:   #d97706;
      --bad:    #dc2626;
      --accent: #2563eb;
      --line:   #e2e8f0;
      --input:  #f8fafc;
      --shadow: 0 18px 50px rgba(15, 23, 42, 0.08);
      /* 五行色系 */
      --wx-wood:   #22c55e;
      --wx-fire:   #ef4444;
      --wx-earth:  #d97706;
      --wx-metal:  #64748b;
      --wx-water:  #2563eb;
    }
    
    /* ── 深色模式 ───────────────────────────────────── */
    :root.dark-mode {
      --bg:     #0f172a;
      --bg-grad:#1e293b;
      --panel:  #1e293b;
      --text:   #f1f5f9;
      --muted:  #94a3b8;
      --ok:     #22c55e;
      --warn:   #f59e0b;
      --bad:    #ef4444;
      --accent: #3b82f6;
      --line:   #334155;
      --input:  #0f172a;
      --shadow: 0 18px 50px rgba(0, 0, 0, 0.5);
    }
    :root.dark-mode body {
      background:radial-gradient(1200px circle at 10% 10%, rgba(59,130,246,.15), transparent 40%),
                 radial-gradient(900px circle at 80% 0%, rgba(14,165,233,.12), transparent 40%),
                 linear-gradient(180deg, var(--bg) 0%, var(--bg-grad) 100%);
    }
    :root.dark-mode header {
      background:rgba(15,23,42,.95);
      border-bottom-color:#334155;
    }
    :root.dark-mode input, :root.dark-mode select {
      background:var(--input);
      border-color:var(--line);
      color:var(--text);
    }
    :root.dark-mode input:focus, :root.dark-mode select:focus {
      background:#1e293b;
    }
    :root.dark-mode pre {
      background:#020617;
      border-color:#1e293b;
    }
    :root.dark-mode .pillar-table th {
      background:#1e293b;
      color:#cbd5e1;
    }
    :root.dark-mode .pillar-table tr:hover td {
      background:rgba(59,130,246,.08);
    }
    *, *::before, *::after { box-sizing: border-box; }
    body {
      margin:0; font-family: "DM Sans","Segoe UI","PingFang SC","Microsoft YaHei",sans-serif;
      background:radial-gradient(1200px circle at 10% 10%, rgba(37,99,235,.08), transparent 40%),
                 radial-gradient(900px circle at 80% 0%, rgba(14,165,233,.08), transparent 40%),
                 linear-gradient(180deg, var(--bg) 0%, var(--bg-grad) 100%);
      color:var(--text); font-size:14px; line-height:1.6; min-height:100vh;
    }
    code { font-family:"Cascadia Code","Fira Code",Consolas,monospace; font-size:12px; }

    /* ── 顶栏 ─────────────────────────────────────────── */
    header {
      padding:14px 20px; border-bottom:1px solid var(--line);
      position:sticky; top:0; background:rgba(247,248,251,.92);
      backdrop-filter:blur(14px); z-index:20;
      display:flex; align-items:center; gap:14px;
    }
    header h1 { margin:0; font-size:20px; letter-spacing:0.3px; flex:1; }
    #statusBar { display:flex; align-items:center; gap:8px; font-size:12px; color:var(--muted); transition:color .2s; }
    #statusBar.ok   { color:#15803d; }
    #statusBar.warn { color:#b45309; }
    #statusBar.bad  { color:#b91c1c; }
    .spinner {
      width:13px; height:13px; border-radius:50%;
      border:2px solid rgba(125,211,252,.2); border-top-color:var(--accent);
      animation:spin .7s linear infinite; display:none;
    }
    .spinner.active { display:inline-block; }
    @keyframes spin { to { transform:rotate(360deg); } }

    /* ── 主体 ─────────────────────────────────────────── */
    .shell { max-width:1240px; margin:0 auto; padding:18px 18px 28px; }
    .hero { display:flex; flex-direction:column; gap:6px; background:linear-gradient(120deg, rgba(37,99,235,.08), rgba(14,165,233,.06)); }
    main.layout { display:grid; gap:16px; grid-template-columns:1fr; align-items:start; }
    .stack { display:flex; flex-direction:column; gap:14px; }
    @media (min-width:1080px) { main.layout { grid-template-columns:0.95fr 1.05fr; } }

    /* ── 卡片 ─────────────────────────────────────────── */
    .card { background:var(--panel); border:1px solid var(--line); border-radius:16px; padding:16px; box-shadow:var(--shadow); }
    details.card { padding:0; overflow:hidden; }
    details.card[open] { box-shadow:var(--shadow); }
    details.card summary { padding:14px 16px; cursor:pointer; display:flex; align-items:center; gap:10px; list-style:none; background:linear-gradient(120deg, rgba(37,99,235,.05), rgba(14,165,233,.04)); border-bottom:1px solid var(--line); font-weight:700; color:var(--text); }
    details.card summary::-webkit-details-marker { display:none; }
    details.card .card-body { padding:14px 16px 16px; }
    .card-title {
      font-size:12px; font-weight:700; color:var(--muted);
      text-transform:uppercase; letter-spacing:.07em;
      margin:0 0 14px; display:flex; align-items:center; gap:7px;
    }
    .card-title .dot { width:6px; height:6px; border-radius:50%; background:var(--accent); flex-shrink:0; }

    /* ── 网格 ─────────────────────────────────────────── */
    .g2  { display:grid; gap:12px; }
    .g2x { display:grid; gap:12px; }
    @media (min-width:768px)  { .g2  { grid-template-columns:1fr 1fr; } }
    @media (min-width:1024px) { .g2x { grid-template-columns:0.6fr 0.4fr; } }

    /* ── 表单 ─────────────────────────────────────────── */
    .field { display:flex; flex-direction:column; gap:4px; }
    label.lbl { font-size:12px; font-weight:600; color:var(--muted); }
    input[type="text"], input[type="number"], select {
      width:100%; padding:10px 12px; border-radius:12px;
      border:1px solid var(--line); background:var(--input);
      color:var(--text); font-size:13px; outline:none;
      transition:border-color .15s, box-shadow .15s, background .15s;
    }
    input:focus, select:focus { border-color:var(--accent); box-shadow:0 0 0 3px rgba(37,99,235,.16); background:#fff; }
    input:focus-visible, select:focus-visible, button:focus-visible { outline:2px solid var(--accent); outline-offset:2px; }
    input.err { border-color:var(--bad); box-shadow:0 0 0 3px rgba(239,68,68,.13); }
    input[type="checkbox"] { width:auto; accent-color:var(--accent); }
    .hint { font-size:11px; color:var(--muted); line-height:1.45; }

    /* ── 按钮 ─────────────────────────────────────────── */
    .row { display:flex; gap:8px; flex-wrap:wrap; align-items:center; }
    .chips { display:flex; gap:6px; flex-wrap:wrap; }
    button {
      border:1px solid var(--line); background:#eef2ff;
      color:#1f2937; padding:9px 14px; border-radius:12px;
      cursor:pointer; font-size:13px; font-weight:600;
      transition:background .15s, border-color .15s, transform .08s, box-shadow .15s;
      white-space:nowrap;
    }
    .result-box { border:1px solid var(--line); border-radius:12px; padding:12px; background:var(--panel); }
    button:hover  { background:#e0e7ff; border-color:#cbd5e1; }
    button:active { transform:scale(.97); }
    button.primary { background:#2563eb; border-color:#1d4ed8; color:#f8fafc; }
    button.primary:hover { background:#1d4ed8; }
    button:disabled { opacity:.5; cursor:not-allowed; transform:none; }
    button.copied { border-color:rgba(34,197,94,.5); color:#86efac; }

    /* ── Pills / Tags / Chips ────────────────────────── */
    .pill { display:inline-flex; align-items:center; gap:5px; padding:4px 10px; border-radius:999px; border:1px solid var(--line); background:var(--input); font-size:11px; color:var(--muted); }
    .pill.ok   { color:#15803d; border-color:rgba(34,197,94,.4);  background:rgba(34,197,94,.06); }
    .pill.warn { color:#92400e; border-color:rgba(245,158,11,.4); background:rgba(245,158,11,.06); }
    .pill.bad  { color:#991b1b; border-color:rgba(239,68,68,.4);  background:rgba(239,68,68,.06); }
    .tag { display:inline-flex; align-items:center; padding:3px 8px; border-radius:6px; border:1px solid var(--line); background:var(--input); font-size:11px; color:var(--muted); }
    .tag.ok   { color:#15803d; border-color:rgba(34,197,94,.35);  background:rgba(34,197,94,.07); }
    .tag.warn { color:#92400e; border-color:rgba(245,158,11,.35); background:rgba(245,158,11,.07); }
    .tag.bad  { color:#991b1b; border-color:rgba(239,68,68,.35);  background:rgba(239,68,68,.07); }
    .chip { display:inline-flex; align-items:center; gap:4px; padding:4px 10px; border-radius:999px; background:#eef2ff; color:#3730a3; font-size:13px; border:1px solid #e5e7eb; white-space:nowrap; }
    .chip.ok { background:#ecfdf3; color:#166534; border-color:#bbf7d0; }
    .chip.warn { background:#fff7ed; color:#9a3412; border-color:#fed7aa; }
    .chip.bad { background:#fef2f2; color:#991b1b; border-color:#fecdd3; }
    .pill-grid { display:grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap:8px; }

    /* ── KV行 ─────────────────────────────────────────── */
    .kv { display:grid; grid-template-columns:160px 1fr; gap:6px 12px; font-size:13px; align-items:center; }
    .kv .k { color:var(--muted); }

    /* ── Level badge ──────────────────────────────────── */
    .level-badge { display:inline-flex; align-items:center; gap:6px; padding:5px 12px; border-radius:8px; font-size:13px; font-weight:700; border:1px solid; }
    .level-badge.ok   { color:#15803d; border-color:rgba(34,197,94,.4);  background:rgba(34,197,94,.08); }
    .level-badge.warn { color:#92400e; border-color:rgba(245,158,11,.4); background:rgba(245,158,11,.08); }
    .level-badge.bad  { color:#991b1b; border-color:rgba(239,68,68,.4);  background:rgba(239,68,68,.08); }
    .level-badge.info { color:#0369a1; border-color:rgba(125,211,252,.35); background:rgba(125,211,252,.07); }

    /* ── 四柱表格 ─────────────────────────────────────── */
    .pillar-table { width:100%; border-collapse:collapse; font-size:13px; border-radius:12px; overflow:hidden; }
    .pillar-table th { background:#eef2ff; color:#475569; font-size:11px; font-weight:700; padding:8px 11px; text-align:left; border-bottom:1px solid var(--line); }
    .pillar-table td { padding:8px 11px; border-bottom:1px solid #e5e7eb; vertical-align:top; }
    .pillar-table tr:last-child td { border-bottom:none; }
    .pillar-table tr:hover td { background:rgba(37,99,235,.02); }
    .gan  { font-size:20px; font-weight:700; }
    .zhi  { font-size:16px; color:#64748b; }
    .sub2 { font-size:11px; color:var(--muted); margin-top:2px; }

    /* ── 天干五行配色 ─────────────────────────────────── */
    .wx-wood   { color: var(--wx-wood); }
    .wx-fire   { color: var(--wx-fire); }
    .wx-earth  { color: var(--wx-earth); }
    .wx-metal  { color: var(--wx-metal); }
    .wx-water  { color: var(--wx-water); }
    .gan-mu   { color: #4ade80; }
    .gan-huo  { color: #f87171; }
    .gan-tu   { color: #fbbf24; }
    .gan-jin  { color: #94a3b8; }
    .gan-shui { color: #60a5fa; }

    /* ── diff高亮 ─────────────────────────────────────── */
    .diff-row td { background: rgba(245,158,11,.08) !important; }
    .diff-row td:first-child::after { content:" △"; color:var(--warn); font-size:10px; }

    /* ── 历史列表 ─────────────────────────────────────── */
    .hist-list { display:flex; flex-direction:column; gap:5px; max-height:200px; overflow-y:auto; }
    .hist-item { display:flex; gap:8px; align-items:center; padding:7px 10px; border-radius:9px; border:1px solid var(--line); background:var(--input); cursor:pointer; transition:background .12s, border-color .12s; }
    .hist-item:hover { background:#e6edff; border-color:#c7d2fe; }
    .hist-body { flex:1; min-width:0; }
    .hist-dt { font-size:12px; color:var(--text); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .hist-rid { font-size:11px; color:var(--muted); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; font-family:monospace; }
    .hist-ts { font-size:11px; color:var(--muted); white-space:nowrap; }

    /* ── Warnings ─────────────────────────────────────── */
    .warnlist { display:flex; flex-direction:column; gap:7px; }
    .warnitem { border-left:3px solid rgba(245,158,11,.65); padding:8px 11px; background:rgba(245,158,11,.05); border-radius:0 9px 9px 0; }
    .warnitem .wcode { color:#92400e; font-size:11px; }
    .warnitem .wmsg  { color:var(--muted); font-size:12px; margin-top:2px; }

    /* ── 空状态 ─────────────────────────────────────── */
    .empty-state { display:flex; align-items:center; gap:12px; padding:12px; border:1px dashed var(--line); border-radius:12px; background:linear-gradient(135deg, rgba(37,99,235,.05), rgba(148,163,184,.06)); color:var(--muted); margin-bottom:10px; }
    .empty-icon { width:34px; height:34px; border-radius:10px; background:rgba(37,99,235,.12); display:grid; place-items:center; color:var(--accent); font-weight:700; }

    /* ── 注释 ─────────────────────────────────────────── */
    .note { border:1px solid var(--line); border-radius:12px; padding:12px; background:#f8fafc; display:grid; gap:10px; }
    .note h4 { margin:0; font-size:13px; color:var(--text); }
    .note ul { margin:0; padding-left:18px; color:var(--muted); font-size:12px; line-height:1.5; }
    .note code { background:#e2e8f0; color:#111827; padding:1px 4px; border-radius:6px; }

    /* ── 摘要 ─────────────────────────────────────────── */
    .summary-grid { display:grid; gap:10px; grid-template-columns:repeat(auto-fit,minmax(140px,1fr)); margin-bottom:10px; }
    .summary-card { border:1px solid var(--line); border-radius:12px; padding:10px 12px; background:linear-gradient(180deg, #ffffff, #f8fbff); display:flex; flex-direction:column; gap:4px; }
    .summary-label { font-size:11px; color:var(--muted); letter-spacing:0.02em; text-transform:uppercase; }
    .summary-value { font-size:18px; font-weight:800; color:var(--text); }
    .summary-pill { display:inline-flex; align-items:center; gap:6px; padding:2px 8px; border-radius:999px; font-size:11px; }
    .summary-pill.ok { background:rgba(34,197,94,.12); color:#166534; }
    .summary-pill.warn { background:rgba(234,179,8,.16); color:#854d0e; }
    .summary-pill.bad { background:rgba(239,68,68,.14); color:#991b1b; }

    /* ── 信息卡 ───────────────────────────────────────── */
    .info-card { border:1px solid var(--line); border-radius:14px; padding:14px; background:#fff; box-shadow:var(--shadow); }
    .info-title { margin:0 0 10px; font-size:13px; font-weight:800; color:var(--text); display:flex; gap:8px; align-items:center; flex-wrap:wrap; }
    .info-title .badge { padding:2px 8px; border-radius:999px; background:#e2e8f0; color:#334155; font-size:11px; }
    .info-list { list-style:none; padding:0; margin:0; display:grid; gap:8px; font-size:12px; color:var(--muted); }
    .info-list li { display:flex; gap:8px; align-items:flex-start; }
    .dot-icon { width:8px; height:8px; margin-top:5px; border-radius:50%; background:var(--accent); flex-shrink:0; }
    .badge-risk { padding:2px 6px; border-radius:999px; background:rgba(234,179,8,.16); color:#854d0e; font-size:11px; }
    .badge-safe { padding:2px 6px; border-radius:999px; background:rgba(34,197,94,.12); color:#166534; font-size:11px; }
    .badge-soft { padding:2px 6px; border-radius:999px; background:#e2e8f0; color:#475569; font-size:11px; }
    .footer { margin-top:16px; padding:12px; border:1px solid var(--line); border-radius:14px; background:#f8fafc; color:#475569; font-size:12px; line-height:1.5; }

    /* ── Tabs ─────────────────────────────────────────── */
    .tabs { display:flex; gap:8px; margin:8px 0 12px; flex-wrap:wrap; }
    .tab-btn { border:1px solid var(--line); background:#f8fafc; color:#1f2937; padding:7px 12px; border-radius:10px; font-size:12px; cursor:pointer; transition:all .12s; }
    .tab-btn.active { background:#2563eb; color:#f8fafc; border-color:#1d4ed8; box-shadow:0 6px 20px rgba(37,99,235,.18); }
    .tab-panel { display:none; font-size:13px; color:#0f172a; line-height:1.55; }
    .tab-panel.active { display:block; }
    .panel-list { margin:0; padding-left:18px; color:#5f6b86; }
    .panel-list li { margin-bottom:4px; }

    .decision-strip { display:flex; flex-wrap:wrap; gap:8px; align-items:center; margin:6px 0 10px; }
    .nav-tags { position:sticky; top:58px; z-index:12; display:flex; flex-wrap:wrap; gap:8px; margin:10px 0 6px; padding:6px 8px; background:rgba(247,248,251,.9); backdrop-filter:blur(10px); border:1px solid var(--line); border-radius:999px; box-shadow:0 10px 24px rgba(15,23,42,.06); }
    .nav-tags button { background:#fff; border:1px solid var(--line); color:var(--text); padding:7px 12px; border-radius:999px; font-size:12px; cursor:pointer; transition:all .12s; }
    .nav-tags button:hover { border-color:var(--accent); color:var(--accent); box-shadow:0 6px 18px rgba(37,99,235,.12); }
    .nav-tags button.active { border-color:var(--accent); color:#fff; background:var(--accent); box-shadow:0 8px 20px rgba(37,99,235,.22); }
    .section-block { margin-top:12px; padding:12px; border:1px solid var(--line); border-radius:12px; background:linear-gradient(180deg,#fff,#f9fbff); box-shadow:var(--shadow); }
    .section-title { display:flex; align-items:center; gap:6px; font-weight:800; font-size:13px; color:var(--text); margin:0 0 10px; }
    .section-title .dot { width:6px; height:6px; border-radius:50%; background:var(--accent); display:inline-block; }
    .hub-frame { width:100%; min-height:760px; border:1px solid var(--line); border-radius:12px; background:#fff; }
    .hub-tools { display:flex; gap:8px; flex-wrap:wrap; align-items:center; margin-bottom:10px; }
    .hub-tools input { width:280px; max-width:100%; }
    .workspace-tabs { display:flex; gap:8px; flex-wrap:wrap; margin:10px 0 12px; }
    .workspace-tabs button { border-radius:999px; background:#fff; }
    .workspace-tabs button.active { background:var(--accent); border-color:var(--accent); color:#fff; }

    /* ── pre ──────────────────────────────────────────── */
    pre { margin:0; padding:11px 13px; background:#0f172a; color:#e2e8f0; border:1px solid #1f2937; border-radius:12px; overflow:auto; font-size:11.5px; max-height:260px; font-family:"Cascadia Code","Fira Code",Consolas,monospace; }

    /* ── details ──────────────────────────────────────── */
    details > summary { cursor:pointer; color:var(--muted); font-size:12px; user-select:none; padding:4px 0; }
    details > summary:hover { color:var(--text); }
    .divider { border:none; border-top:1px solid var(--line); margin:14px 0; }
    @media (max-width:500px) { .card { padding:12px; } .gan { font-size:16px; } }

    /* ── 命盘概要 ─────────────────────────────────────── */
    .profile-grid {
      display:grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap:12px; margin-top:10px;
    }
    .profile-item {
      border:1px solid var(--line); border-radius:12px; padding:12px;
      background:linear-gradient(180deg,#fff,#f8fbff);
    }
    .profile-label { font-size:11px; color:var(--muted); text-transform:uppercase; letter-spacing:.04em; margin-bottom:4px; }
    .profile-value { font-size:16px; font-weight:800; color:var(--text); }
    .profile-sub { font-size:11px; color:var(--muted); margin-top:2px; }

    /* ── 五行条形图 ───────────────────────────────────── */
    .wx-bar-wrap { margin-top:10px; }
    .wx-bar-row { display:flex; align-items:center; gap:8px; margin:4px 0; font-size:12px; }
    .wx-bar-label { width:32px; text-align:right; font-weight:700; flex-shrink:0; }
    .wx-bar-track { flex:1; height:18px; background:#f1f5f9; border-radius:9px; overflow:hidden; position:relative; }
    .wx-bar-fill { height:100%; border-radius:9px; transition:width .5s ease; display:flex; align-items:center; justify-content:flex-end; padding-right:6px; font-size:10px; font-weight:700; color:#fff; min-width:20px; }
    .wx-bar-fill.wood  { background:linear-gradient(90deg,#16a34a,#4ade80); }
    .wx-bar-fill.fire  { background:linear-gradient(90deg,#dc2626,#f87171); }
    .wx-bar-fill.earth { background:linear-gradient(90deg,#b45309,#fbbf24); }
    .wx-bar-fill.metal { background:linear-gradient(90deg,#475569,#94a3b8); }
    .wx-bar-fill.water { background:linear-gradient(90deg,#1d4ed8,#60a5fa); }

    /* ── 十神标签 ─────────────────────────────────────── */
    .tengod-badge { display:inline-flex; align-items:center; gap:3px; padding:2px 8px; border-radius:999px; font-size:11px; font-weight:600; border:1px solid var(--line); background:var(--input); color:var(--text); }
    .tengod-badge.self     { background:#dbeafe; border-color:#93c5fd; color:#1e40af; }
    .tengod-badge.resource { background:#dcfce7; border-color:#86efac; color:#166534; }
    .tengod-badge.output   { background:#fef3c7; border-color:#fde68a; color:#92400e; }
    .tengod-badge.wealth   { background:#fce7f3; border-color:#f9a8d4; color:#9d174d; }
    .tengod-badge.power    { background:#ede9fe; border-color:#c4b5fd; color:#5b21b6; }

    /* ── 解读区 / 参考区 ─────────────────────────────── */
    .interpret-zone { margin-top:16px; padding:16px; border:1px solid var(--line); border-radius:16px; background:linear-gradient(180deg,#fff,#f9fbff); box-shadow:var(--shadow); }
    .interpret-zone > .card, .interpret-zone > div { margin-top:12px; }
    .interpret-zone > .section-title { margin-top:0; }
    .ref-zone { margin-top:16px; padding:4px 0; }
    .ref-zone > .info-card, .ref-zone > .card { margin-top:12px; }

    /* ── 大运表增强 ─────────────────────────────────── */
    .dayun-table { width:100%; border-collapse:collapse; font-size:12px; border-radius:12px; overflow:hidden; }
    .dayun-table th { background:#eef2ff; color:#475569; font-size:11px; font-weight:700; padding:8px 10px; text-align:center; border-bottom:1px solid var(--line); white-space:nowrap; }
    .dayun-table td { padding:8px 10px; border-bottom:1px solid #e5e7eb; text-align:center; vertical-align:top; }
    .dayun-table tr:hover td { background:rgba(37,99,235,.02); }
    .dayun-table .dayun-gz { font-size:16px; font-weight:700; }

    /* ── 用神忌神配色 ─────────────────────────────────── */
    .favor-chip { background:#ecfdf3; color:#166534; border-color:#86efac; }
    .avoid-chip { background:#fef2f2; color:#991b1b; border-color:#fca5a5; }

    /* ── 四柱大卡片 ─────────────────────────────────── */
    .pillar-cards { display:grid; grid-template-columns:repeat(4,1fr); gap:10px; }
    .pillar-card { border:1px solid var(--line); border-radius:14px; padding:14px 10px; text-align:center; background:linear-gradient(180deg,#fff,#f8fbff); position:relative; }
    .pillar-card.day-master { border-color:var(--accent); box-shadow:0 0 0 2px rgba(37,99,235,.12); }
    .pillar-card .pc-label { font-size:11px; color:var(--muted); font-weight:700; letter-spacing:.04em; }
    .pillar-card .pc-stem { font-size:32px; font-weight:800; line-height:1.2; }
    .pillar-card .pc-branch { font-size:22px; color:#64748b; margin-top:2px; }
    .pillar-card .pc-gz { font-size:11px; color:var(--muted); margin-top:4px; }
    @media (max-width:500px) { .pillar-cards { grid-template-columns:repeat(2,1fr); } .pillar-card .pc-stem { font-size:24px; } }

    /* ── 工作区过渡动画 ──────────────────────────────── */
    #verifyMain, #casesHub, #caseDetailHub, #verifyNavTags, #interpretSection, #referenceSection, #footerShell {
      transition: opacity 0.3s ease, visibility 0.3s ease;
    }
    /* 工作区标签高亮 */
    .workspace-tabs button { transition: background 0.2s ease, color 0.2s ease; }
    .workspace-tabs button.active { animation: tabBounce 0.4s ease; }
    @keyframes tabBounce { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.05); } }
    
    /* 快速返回按钮样式 */
    .quick-back-btn { padding:8px 14px; background:var(--accent); color:#fff; border:none; border-radius:8px; cursor:pointer; font-weight:600; transition:background 0.2s; }
    .quick-back-btn:hover { background:var(--accent); opacity:0.9; }
    
    /* 工作区标签位置 */
    .workspace-tabs { display:flex; gap:8px; padding:10px 0; border-bottom:1px solid var(--line); flex-wrap:wrap; }
    .workspace-tabs button { padding:8px 16px; border:1px solid var(--line); border-radius:8px; background:var(--input); color:var(--muted); cursor:pointer; font-weight:600; transition:all 0.2s; }
    .workspace-tabs button:hover { background:var(--panel); border-color:var(--accent); }
    .workspace-tabs button.active { background:var(--accent); color:#fff; border-color:var(--accent); }
    
    /* 帮助面板 */
    .help-panel { 
      position:fixed; top:50%; left:50%; transform:translate(-50%, -50%);
      background:var(--panel); border:1px solid var(--line); border-radius:16px;
      padding:24px; max-width:500px; width:90%; max-height:80vh; overflow-y:auto;
      box-shadow:0 20px 60px rgba(0,0,0,0.3); z-index:1000; display:none;
    }
    .help-panel.show { display:block; animation:slideDown 0.3s ease; }
    @keyframes slideDown { from { opacity:0; transform:translate(-50%, -55%); } to { opacity:1; transform:translate(-50%, -50%); } }
    .help-panel h2 { margin:0 0 16px; color:var(--accent); font-size:20px; }
    .help-panel .help-section { margin-bottom:20px; }
    .help-panel .help-section h3 { margin:8px 0 12px; font-size:14px; color:var(--text); }
    .help-panel .help-item { display:flex; gap:12px; margin-bottom:8px; font-size:13px; line-height:1.5; }
    .help-panel .help-key { background:var(--input); padding:4px 8px; border-radius:6px; font-family:monospace; font-weight:700; white-space:nowrap; color:var(--accent); }
    .help-panel .help-close { position:absolute; top:16px; right:16px; background:none; border:none; font-size:20px; cursor:pointer; color:var(--muted); }
    .help-overlay { position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.3); z-index:999; display:none; }
    .help-overlay.show { display:block; }

    /* 模板下拉菜单及样式 */
    .dropdown-menu { box-shadow:var(--shadow); }
    .dropdown-item { 
      padding:8px 12px; cursor:pointer; border-radius:6px; margin-bottom:4px;
      display:flex; justify-content:space-between; align-items:center;
      background:var(--input); transition:background 0.15s;
    }
    .dropdown-item:hover { background:rgba(37,99,235,.1); }
    .dropdown-item-name { flex:1; font-weight:600; }
    .dropdown-item-delete { font-size:12px; color:var(--muted); cursor:pointer; padding:2px 6px; }
    .dropdown-item-delete:hover { color:var(--bad); }
    .dropdown-empty { padding:12px; text-align:center; color:var(--muted); font-size:12px; }

    /* 分析面板样式 */
    .analytics-modal { max-width:1000px; max-height:85vh; overflow-y:auto; }
    .analytics-container { padding:20px; }
    .stats-grid { display:grid; grid-template-columns:repeat(auto-fit, minmax(150px, 1fr)); gap:12px; margin-bottom:20px; }
    .stat-card { background:linear-gradient(135deg, #f0f4ff 0%, #e8f1ff 100%); padding:16px; border-radius:10px; text-align:center; border-left:4px solid var(--accent); }
    .stat-number { font-size:28px; font-weight:700; color:var(--accent); margin-bottom:4px; }
    .stat-label { font-size:12px; color:var(--muted); font-weight:600; }
    .analytics-table tbody tr:hover { background:var(--input); }
    .analytics-table td, .analytics-table th { padding:10px 8px; }
    
    @media (max-width:768px) {
      .stats-grid { grid-template-columns:repeat(2, 1fr); }
      .stat-number { font-size:24px; }
    }
    
    @media (max-width:500px) {
      .analytics-modal { padding:12px; }
      .stats-grid { grid-template-columns:1fr; gap:8px; }
      .stat-card { padding:12px; }
      .stat-number { font-size:20px; }
      .charts-section { padding:8px; }
    }

    /* ── 响应式设计优化 ──────────────────────────── */
    @media (max-width:768px) {
      header { flex-wrap:wrap; gap:8px; padding:10px 14px; }
      header h1 { font-size:16px; margin-bottom:4px; flex-basis:100%; }
      header > span { font-size:11px; flex-basis:100%; }
      header > div:nth-of-type(1) { flex-wrap:wrap; gap:6px; }
      header > div:nth-of-type(1) > button, header > div:nth-of-type(1) > .pill { 
        padding:6px 8px; font-size:11px; 
      }
      #statusBar { position:absolute; bottom:-20px; left:14px; font-size:11px; }
      
      .shell { padding:12px 12px 24px; }
      main.layout { grid-template-columns:1fr; }
      .g2, .g2x { grid-template-columns:1fr !important; }
      
      .card { padding:12px; border-radius:12px; }
      .card-title { font-size:11px; margin-bottom:10px; }
      
      input[type="text"], input[type="number"], select { 
        padding:8px 10px; font-size:12px; 
      }
      
      button { 
        padding:7px 11px; font-size:12px; 
      }
      button.primary { padding:8px 12px; }
      
      .row { gap:6px; }
      .pill { padding:3px 8px; font-size:10px; }
      
      .workspace-tabs { gap:6px; padding:8px 0; }
      .workspace-tabs button { padding:6px 12px; font-size:12px; }
      
      .summary-grid { grid-template-columns:1fr; gap:10px; }
      .pillar-cards { grid-template-columns:repeat(2,1fr); gap:8px; }
      .pillar-card .pc-stem { font-size:20px; }
      .pillar-card .pc-branch { font-size:14px; }
      
      .nav-tags { flex-wrap:wrap; gap:6px; }
      .nav-tags button { padding:5px 10px; font-size:11px; }
      
      .kv { grid-template-columns:80px 1fr; gap:4px 10px; }
      .kv .k { font-size:12px; }
      .kv .v { font-size:12px; }
      
      hr.divider { margin:10px 0; }
      details summary { font-size:11px; }
      
      .help-panel { width:95%; max-width:90vw; padding:16px; }
      .help-panel h2 { font-size:16px; margin-bottom:12px; }
      .help-panel .help-section h3 { font-size:12px; }
      .help-item { font-size:12px; gap:8px; }
      .help-key { padding:3px 6px; font-size:10px; }
      
      #verifyNavTags { gap:4px; }
      #verifyNavTags button { padding:4px 8px; font-size:10px; }
    }
    
    @media (max-width:500px) {
      header h1 { font-size:14px; }
      header > span { display:none; }
      
      .shell { padding:10px 10px 20px; }
      .card { padding:10px; border-radius:10px; }
      
      input[type="text"], input[type="number"], select { 
        padding:6px 8px; font-size:11px; 
      }
      
      button { padding:6px 10px; font-size:11px; }
      .pill { padding:2px 6px; font-size:9px; }
      
      .summary-grid { display:flex; flex-direction:column; }
      .summary-card { padding:10px; }
      .summary-label { font-size:11px; }
      .summary-value { font-size:14px; }
      
      .kv { grid-template-columns:70px 1fr; gap:2px 8px; font-size:11px; }
      
      .pillar-card { padding:10px 6px; }
      .pillar-card .pc-stem { font-size:16px; }
      .pillar-card .pc-branch { font-size:12px; }
      .pc-label { font-size:9px; }
      
      #histDetails summary { font-size:10px; }
      
      .dropdown-item { padding:6px 10px; font-size:11px; }
      .dropdown-item-name { font-size:12px; }
      .dropdown-item-delete { font-size:10px; padding:2px 4px; }
    }
  </style>
</head>
<body>
<script src="/static/js/relation-shared.js"></script>

<header>
  <h1>八字命理验证</h1>
  <span style="color:var(--muted);font-size:12px;">一体化工作台：验证 + 案例 + 详情</span>
  <div style="display:flex;align-items:center;gap:8px;margin-left:auto;">
    <button class="pill" id="btn-go-verify" aria-label="跳转验证区">验证区</button>
    <button class="pill" id="btn-go-cases" aria-label="跳转案例中心">案例中心</button>
    <button class="pill" id="btn-go-detail" aria-label="跳转案例详情">案例详情</button>
    <button id="btn-favorite" title="收藏管理" style="padding:6px 10px;font-size:12px;border-radius:8px;">⭐ 收藏</button>
    <button id="btn-compare" title="对比两个八字" style="padding:6px 10px;font-size:12px;border-radius:8px;">⚖️ 对比</button>
    <button id="btn-analytics" title="历史数据统计分析" style="padding:6px 10px;font-size:12px;border-radius:8px;">📊 统计</button>
    <button id="btn-export" title="导出结果" style="padding:6px 10px;font-size:12px;border-radius:8px;">📥 导出</button>
    <button id="btn-help" title="快捷键帮助" style="padding:6px 10px;font-size:12px;border-radius:8px;">❓ 帮助</button>
    <button id="btn-dark-toggle" title="切换深色/浅色模式" style="padding:6px 10px;font-size:12px;border-radius:8px;">🌙 深色</button>
  </div>
  <div id="statusBar">
    <div class="spinner" id="spinner"></div>
    <span id="statusText"></span>
  </div>
</header>

<div id="helpOverlay" class="help-overlay"></div>
<div id="helpPanel" class="help-panel">
  <button class="help-close" onclick="closeHelpPanel()">✕</button>
  <h2>快捷键 & 功能提示</h2>
  
  <div class="help-section">
    <h3>🎯 工作区切换（键盘快捷键）</h3>
    <div class="help-item">
      <span class="help-key">1</span>
      <span>切换到<strong>验证工作区</strong>（排盘计算）</span>
    </div>
    <div class="help-item">
      <span class="help-key">2</span>
      <span>切换到<strong>案例工作区</strong>（案例管理）</span>
    </div>
    <div class="help-item">
      <span class="help-key">3</span>
      <span>切换到<strong>详情工作区</strong>（单案例查看）</span>
    </div>
  </div>

  <div class="help-section">
    <h3>🔍 案例搜索 & 批量操作</h3>
    <div class="help-item">搜索框：输入关键字快速筛选案例</div>
    <div class="help-item">批量对比：选中 2+ 案例后点击"对比"按钮进行对标</div>
  </div>

  <div class="help-section">
    <h3>💾 数据持久化</h3>
    <div class="help-item">✓ 自动保存输入参数到本地</div>
    <div class="help-item">✓ 排盘结果缓存到 IndexedDB（离线可用）</div>
    <div class="help-item">✓ 记住最后使用的工作区（下次自动恢复）</div>
  </div>

  <div class="help-section">
    <h3>📌 其他功能</h3>
    <div class="help-item">⭐ 收藏：保存喜爱的八字案例</div>
    <div class="help-item">⚖️ 对比：对比两个不同的八字</div>
    <div class="help-item">📥 导出：导出排盘结果为 JSON</div>
    <div class="help-item">🌙 深色：切换深色/浅色模式</div>
  </div>

  <div style="margin-top:20px; padding-top:16px; border-top:1px solid var(--line); font-size:12px; color:var(--muted);">
    💡 提示：在输入框中时，键盘快捷键被禁用（防止冲突）
  </div>
</div>

  <section class="card hero" aria-label="页面导览">
    <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
      <div style="padding:6px 10px;border-radius:10px;background:#e0e7ff;color:#1e3a8a;font-weight:700;">八字排盘</div>
      <span style="color:var(--muted);">输入出生时间，自动排盘 · 五行分析 · 十神推算 · 大运排列</span>
    </div>
    <div style="display:flex;gap:10px;flex-wrap:wrap;color:var(--muted);font-size:12px;">
      <span class="tag">四柱排盘</span>
      <span class="tag">五行强弱</span>
      <span class="tag">十神分析</span>
      <span class="tag">用神忌神</span>
      <span class="tag">大运推算</span>
      <span class="tag">案例管理</span>
      <span class="tag">案例详情</span>
    </div>
  </section>

  <div class="nav-tags" id="verifyNavTags" aria-label="快速跳转">
    <button data-target="reqCard">请求</button>
    <button data-target="profileSection">命盘</button>
    <button data-target="summarySection">摘要</button>
    <button data-target="diagSection">诊断</button>
    <button data-target="interpretSection">解读</button>
    <button data-target="referenceSection">参考</button>
    <button data-target="casesHub">案例</button>
    <button data-target="caseDetailHub">详情</button>
  </div>

  <div class="workspace-tabs" id="workspaceTabs" aria-label="工作区切换">
    <button data-mode="verify" class="active">验证工作区</button>
    <button data-mode="cases">案例工作区</button>
    <button data-mode="detail">详情工作区</button>
  </div>

<main class="layout" id="verifyMain">
  <div class="stack">
  <!-- ── 输入卡片 ─────────────────────────────────────── -->
  <section class="card" id="reqCard" style="height:fit-content;">
    <p class="card-title"><span class="dot"></span>请求参数</p>
    
    <!-- 个人基本信息 -->
    <div class="g2" style="margin-bottom:16px;">
      <div class="field">
        <label class="lbl" for="userName">姓名</label>
        <input id="userName" type="text" placeholder="例：张三" style="flex:1;" />
        <span class="hint">可选，用于记录和显示</span>
      </div>
      <div class="field">
        <label class="lbl" for="userGender">性别</label>
        <select id="userGender">
          <option value="">未指定</option>
          <option value="male">男</option>
          <option value="female">女</option>
        </select>
        <span class="hint">可选，部分分析参考</span>
      </div>
    </div>
    
    <div class="field" style="margin-bottom:16px;">
      <label class="lbl" for="birthPlace">出生地点</label>
      <input id="birthPlace" type="text" placeholder="例：上海市浦东新区" style="flex:1;" />
      <span class="hint">可选，地理位置记录</span>
    </div>
    
    <hr class="divider" style="margin:16px 0;" />
    
    <div class="g2x">
      <div class="field">
        <label class="lbl" for="dt">出生时间（阳历）&nbsp;<span style="color:var(--bad)">*</span></label>
        <div class="row">
          <input id="dt" type="datetime-local" style="flex:1;" />
          <button id="btn-now" title="填入当前本地时间">现在</button>
        </div>
        <span class="hint">使用日期时间选择器，或点击"现在"按钮填入当前时间</span>
      </div>
      <div class="g2">
        <div class="field">
          <label class="lbl" for="tz">时区</label>
          <input id="tz" type="text" value="Asia/Shanghai" />
          <span class="hint">IANA 时区名</span>
        </div>
        <div class="field">
          <label class="lbl" for="lon">经度 (70–140) &nbsp;<span style="color:var(--bad)">*</span></label>
          <input id="lon" type="number" step="0.0001" min="70" max="140" value="121.4737" />
          <span class="hint">真太阳时校正用，默认上海</span>
        </div>
      </div>
    </div>
    <div class="g2" style="margin-top:12px;">
      <div class="field">
        <label class="lbl" for="mode">计算模式</label>
        <select id="mode">
          <option value="dual" selected>dual — 双引擎交叉校验</option>
          <option value="single">single — 单引擎</option>
        </select>
        <span class="hint">dual 模式返回两套四柱并标注差异</span>
      </div>
      <div class="field" style="justify-content:center;">
        <label class="lbl">选项</label>
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
          <input id="solar_time_enabled" type="checkbox" />
          <span>真太阳时校正</span>
          <span class="tag">solar_time</span>
        </label>
      </div>
    </div>
    <hr class="divider" />
    <div class="row">
      <button class="primary" id="btn-run">▶ 开始排盘</button>
      <button id="btn-demo">填入示例</button>
      <button id="btn-save-template" title="保存当前参数为方案模板">💾 保存方案</button>
      <div style="position:relative;display:inline-block;">
        <button id="btn-load-template" title="加载已保存的方案">加载方案 ▼</button>
        <div id="templateDropdown" class="dropdown-menu" style="display:none;position:absolute;top:100%;left:0;background:var(--panel);border:1px solid var(--line);border-radius:8px;padding:8px;margin-top:4px;min-width:200px;z-index:100;max-height:300px;overflow-y:auto;">
          <div id="templateList" style="font-size:12px;"></div>
        </div>
      </div>
      <button id="btn-curl">复制 curl</button>
    </div>
  </section>

  <details id="histDetails" style="margin-top:12px;">
    <summary style="cursor:pointer;color:var(--muted);font-size:12px;padding:8px 0;user-select:none;display:flex;align-items:center;gap:6px;">
      <span>历史记录</span>
      <span id="histCount" class="tag" style="font-weight:400;text-transform:none;letter-spacing:0;"></span>
    </summary>
    <div class="card" style="margin-top:10px;padding:12px;">
      <div class="row" style="justify-content:space-between;margin-bottom:10px;">
        <p class="card-title" style="margin:0;"><span class="dot" style="background:var(--muted)"></span>最近请求 <span class="hint">（点击可反填参数）</span></p>
        <button id="btn-clear-hist" style="font-size:11px;padding:4px 10px;">清空</button>
      </div>
      <div class="hist-list" id="histList"></div>

      <!-- Analytics Panel - 合并在历史记录下方 -->
